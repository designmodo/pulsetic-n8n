{
	"compilerOptions": {
		"strict": true,
		"module": "commonjs",
		"target": "ES2019",
		"lib": ["ES2019"],
		"moduleResolution": "node",
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"typeRoots": ["node_modules/@types"]
	},
	"include": ["credentials/**/*", "nodes/**/*"],
	"exclude": ["node_modules", "dist"]
}



